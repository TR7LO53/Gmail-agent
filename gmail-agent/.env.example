# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Required: OpenAI API key for the Classifier and Tracker agents.
OPENAI_API_KEY=sk-...

# Classifier model (small + cheap; runs every heartbeat). Change here to swap, no code edits.
OPENAI_MODEL=gpt-4.1-nano

# Optional: a deeper model for the Tracker agent only. If unset, the Tracker reuses OPENAI_MODEL.
# OPENAI_TRACKER_MODEL=gpt-4.1

# Which Gmail tab Ggent's automated scans look at. Default: primary (ignores Social/Promotions/etc.).
# Set to updates if your carriers land there, or to "all" to scan every tab.
# GGENT_CATEGORY=primary

# How often the one-click launcher (Start Ggent) checks mail, in minutes. Default 5.
# GGENT_INTERVAL_MIN=5

# Dashboard port (used by `npm run serve` and the launcher). Default 3000.
# PORT=3000

# --- Food logging (Discord + USDA FoodData Central) -----------------------
# Discord bot token (Developer Portal → your app → Bot). Enable the Message Content Intent.
# DISCORD_BOT_TOKEN=...
# Your Discord user id, so only you can log food (right-click your name → Copy User ID).
# DISCORD_ALLOWED_USER_ID=...
# USDA FoodData Central API key — free at https://fdc.nal.usda.gov/api-key-signup.html
# (DEMO_KEY works for a quick test but is heavily rate-limited).
# USDA_API_KEY=...
# Daily nutrition targets shown as progress on the dashboard and in chat replies.
# NUTRITION_GOAL_KCAL=2000
# NUTRITION_GOAL_PROTEIN_G=150
# NUTRITION_GOAL_CARBS_G=200
# NUTRITION_GOAL_FAT_G=70
# Optional: transcription model for voice notes (default whisper-1).
# OPENAI_TRANSCRIBE_MODEL=whisper-1
